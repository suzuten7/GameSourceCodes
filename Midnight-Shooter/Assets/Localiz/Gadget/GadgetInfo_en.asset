  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: GadgetInfo_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: cb64414cf0263024795653a60f948ab9, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 53497729781760
    m_Localized: 'Typical grenade

      Can also hit allies'
    m_Metadata:
      m_Items: []
  - m_Id: 53574506516480
    m_Localized: 'Healing Grenade

      Also targets enemies.'
    m_Metadata:
      m_Items: []
  - m_Id: 53576712720384
    m_Localized: Grenade that doesn't slow down
    m_Metadata:
      m_Items: []
  - m_Id: 53758510632960
    m_Localized: 'Player movement and rotation allow for detonation at a different
      location.

      <s>This isn''t a grenade!</s>'
    m_Metadata:
      m_Items: []
  - m_Id: 53789053554688
    m_Localized: 'A grenade that illuminates the surrounding area and makes it visible?

      Damage
      is very low

      If you use this as a final blow, you can call it incitement.'
    m_Metadata:
      m_Items: []
  - m_Id: 53836025565184
    m_Localized: The time it takes for the explosion to occur is very long; it's
      necessary to attack and trigger a chain reaction.
    m_Metadata:
      m_Items: []
  - m_Id: 53914450661376
    m_Localized: It can block bullets from both friend and foe.
    m_Metadata:
      m_Items: []
  - m_Id: 53915218219008
    m_Localized: 'A barricade that can obstruct both visibility and passage.

      Smaller
      than the Bullet Barricade, but more durable.'
    m_Metadata:
      m_Items: []
  - m_Id: 53915843170304
    m_Localized: Create an area that is not visible from the outside.
    m_Metadata:
      m_Items: []
  - m_Id: 54065286221824
    m_Localized: 'Visibility ends

      Generate area'
    m_Metadata:
      m_Items: []
  - m_Id: 54066963943424
    m_Localized: 'Giant grenade

      Deals damage over a wide area'
    m_Metadata:
      m_Items: []
  - m_Id: 54196899287040
    m_Localized: A decoy that continuously emits a reasonable amount of noise.
    m_Metadata:
      m_Items: []
  - m_Id: 54198086275072
    m_Localized: Restores your own HP and injuries.
    m_Metadata:
      m_Items: []
  - m_Id: 54199696887808
    m_Localized: 'Restores your own HP.

      Cannot heal injuries.'
    m_Metadata:
      m_Items: []
  - m_Id: 54355284594688
    m_Localized: Sends a marker that allows for high-speed movement in the direction
      it was sent.
    m_Metadata:
      m_Items: []
  - m_Id: 54356194758656
    m_Localized: A grenade that shatters glass and causes lacerations.
    m_Metadata:
      m_Items: []
  - m_Id: 54442366734336
    m_Localized: Throw a fake bush
    m_Metadata:
      m_Items: []
  - m_Id: 54443562110976
    m_Localized: Place a bridge that ignores the effects of the terrain.
    m_Metadata:
      m_Items: []
  - m_Id: 54574478921728
    m_Localized: Throw a branch that might make a loud noise when stepped on.
    m_Metadata:
      m_Items: []
  - m_Id: 54575246479360
    m_Localized: 'A bomb that sinks into water

      No damage'
    m_Metadata:
      m_Items: []
  - m_Id: 54640174305280
    m_Localized: It throws thorns that hurt anyone who touches them, regardless of
      whether they are friend or foe.
    m_Metadata:
      m_Items: []
  - m_Id: 54641017360384
    m_Localized: It shoots lava that melts anything it touches, regardless of whether
      they are friend or foe.
    m_Metadata:
      m_Items: []
  - m_Id: 54791991332864
    m_Localized: Install a box that can be pressed.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
