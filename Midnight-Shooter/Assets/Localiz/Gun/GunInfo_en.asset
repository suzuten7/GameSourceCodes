MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: GunInfo_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 5880390048378704093c718d3dd3447d, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 14439813120
    m_Localized: Standard firearm
    m_Metadata:
      m_Items: []
  - m_Id: 49301206994944
    m_Localized: It deals more damage than a fully automatic weapon, but the recoil
      is very large.
    m_Metadata:
      m_Items: []
  - m_Id: 49503552802816
    m_Localized: 'A gun that heals in an area based on the reticle''s position.

      You
      have to rely on your teammates.

      <s>It heals enemies too!!!</s>'
    m_Metadata:
      m_Items: []
  - m_Id: 49554115137536
    m_Localized: 'A gun that heals yourself?

      It''s not very useful unless
      you''re the one acting as a shield.'
    m_Metadata:
      m_Items: []
  - m_Id: 49617201664000
    m_Localized: You can't fire by holding down the button, but it has decent accuracy?
    m_Metadata:
      m_Items: []
  - m_Id: 49675213082624
    m_Localized: 'It scatters bullets.

      Its power is low unless multiple shots
      hit.'
    m_Metadata:
      m_Items: []
  - m_Id: 49676609785856
    m_Localized: What is this?
    m_Metadata:
      m_Items: []
  - m_Id: 49814799519744
    m_Localized: 'It scatters a massive amount of bullets around itself!

      Quite
      effective at preventing healing.

      <s>Very noisy</s>'
    m_Metadata:
      m_Items: []
  - m_Id: 49879379218432
    m_Localized: 'Low power, but high rate of fire and high projectile

      velocity
      allow for sustained damage.'
    m_Metadata:
      m_Items: []
  - m_Id: 50056726974464
    m_Localized: 'It fires beams that can penetrate walls, but there''s

      also
      a possibility that its position will be revealed.'
    m_Metadata:
      m_Items: []
  - m_Id: 50214747377664
    m_Localized: The ammo count is unlimited, but...
    m_Metadata:
      m_Items: []
  - m_Id: 50491944734720
    m_Localized: 'A gun that carries the risk of accidentally firing at friendly
      fire.

      <s>It wasn''t on purpose.</s>'
    m_Metadata:
      m_Items: []
  - m_Id: 50558239903744
    m_Localized: Nothing can be shot, nothing happens.
    m_Metadata:
      m_Items: []
  - m_Id: 50639076724736
    m_Localized: 'It has high DPS, but its short range and

      weak damage output
      make it difficult to inflict damage.'
    m_Metadata:
      m_Items: []
  - m_Id: 50640825749504
    m_Localized: 'A shotgun with super-high firepower that can penetrate walls.

      However,
      it takes time to recharge before the next shot can be fired.'
    m_Metadata:
      m_Items: []
  - m_Id: 50909798076416
    m_Localized: 'It has a high projectile velocity and high power.

      Its power
      decreases if you get too close.'
    m_Metadata:
      m_Items: []
  - m_Id: 50968291840000
    m_Localized: 'High rate of fire and projectile velocity

      However, the
      power is quite low'
    m_Metadata:
      m_Items: []
  - m_Id: 51036591886336
    m_Localized: It's very slow, but it has a strong ability to block other bullets.
    m_Metadata:
      m_Items: []
  - m_Id: 51064257515520
    m_Localized: A troublesome ray gun that bounces off walls
    m_Metadata:
      m_Items: []
  - m_Id: 51172600582144
    m_Localized: A gun that inflicts less damage but more injuries.
    m_Metadata:
      m_Items: []
  - m_Id: 51173506551808
    m_Localized: 'Scatters at the point of impact

      Takes longer to reload
      than self-detonated fireworks'
    m_Metadata:
      m_Items: []
  - m_Id: 51292419264512
    m_Localized: 'It explodes at the point of impact and can attack within a range.

      Explosions
      are dangerous as allies will also be affected.'
    m_Metadata:
      m_Items: []
  - m_Id: 51348178341888
    m_Localized: The problem is that even allies can step on the landmines that remain
      stationary.
    m_Metadata:
      m_Items: []
  - m_Id: 51374736674816
    m_Localized: 'A gun with very low power.

      Strong kill score bonus.'
    m_Metadata:
      m_Items: []
  - m_Id: 51476431769600
    m_Localized: 'A gun that fires slow-moving bullets.

      It fires multiple
      shots, but its power is low at close range.'
    m_Metadata:
      m_Items: []
  - m_Id: 52520138182656
    m_Localized: Fires bullets that bounce randomly based on the reticle's position.
    m_Metadata:
      m_Items: []
  - m_Id: 52520893157376
    m_Localized: It has high power, but the recoil is strong and it's noisy.
    m_Metadata:
      m_Items: []
  - m_Id: 52521803321344
    m_Localized: Assault rifle with reduced noise, at the expense of power.
    m_Metadata:
      m_Items: []
  - m_Id: 52729949851648
    m_Localized: 'A sniper rifle with reduced noise.

      It has a small ammunition
      capacity and a long reload time.'
    m_Metadata:
      m_Items: []
  - m_Id: 52731698876416
    m_Localized: 'Boasting immense firepower,

      and easily destroying walls,

      but
      difficult to handle.'
    m_Metadata:
      m_Items: []
  - m_Id: 52872958840832
    m_Localized: 'A shotgun with a high rate of fire and high projectile velocity.

      However,
      it has low power.'
    m_Metadata:
      m_Items: []
  - m_Id: 52874078720000
    m_Localized: Shotgun blasts scatter at the reticle position
    m_Metadata:
      m_Items: []
  - m_Id: 52952919052288
    m_Localized: Shotgun that scatters in the opposite direction at the reticle position
    m_Metadata:
      m_Items: []
  - m_Id: 52953967628288
    m_Localized: 'A ray gun that slows down enemies

      Limited ammunition'
    m_Metadata:
      m_Items: []
  - m_Id: 53063141167104
    m_Localized: 'It can obstruct the enemy''s line of sight.

      Its power is
      mediocre.'
    m_Metadata:
      m_Items: []
  - m_Id: 53064613367808
    m_Localized: 'An assault rifle that can penetrate walls

      However, it lacks
      power.'
    m_Metadata:
      m_Items: []
  - m_Id: 54162904453120
    m_Localized: 'It fires an extremely powerful, wall-piercing laser.

      However,
      there is a time lag before it hits.'
    m_Metadata:
      m_Items: []
  - m_Id: 54240826232832
    m_Localized: It explodes at the reticle's position and inflicts poison.
    m_Metadata:
      m_Items: []
  - m_Id: 54241518292992
    m_Localized: 'It has a large ammunition capacity and high rate of

      fire,
      but it suffers from slow reloading

      and low single-shot damage.'
    m_Metadata:
      m_Items: []
  - m_Id: 54725763272704
    m_Localized: 'Launch three swords

      towards the reticle.'
    m_Metadata:
      m_Items: []
  - m_Id: 54726526636032
    m_Localized: 'It can fire two shots simultaneously.

      However, the power
      of each individual shot is inferior.'
    m_Metadata:
      m_Items: []
  - m_Id: 54791114723328
    m_Localized: He fires two lasers in quick succession, but they miss the reticle.
    m_Metadata:
      m_Items: []
  - m_Id: 54841786109952
    m_Localized: Firing bullets in a line.
    m_Metadata:
      m_Items: []
  - m_Id: 54924334206976
    m_Localized: 'Rapid-fire capability

      Small missile weapon

      May
      be able to utilize knockback'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
