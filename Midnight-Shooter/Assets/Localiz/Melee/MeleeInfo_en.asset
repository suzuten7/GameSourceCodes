  m_SharedData: {fileID: 11400000, guid: 3dff92ae48242754baf5f00cf303f44b, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 2368388075520
    m_Localized: A melee weapon with a wide horizontal range.
    m_Metadata:
      m_Items: []
  - m_Id: 2324154945536
    m_Localized: 'Movement and attack speeds are high,

      but its ability to
      inflict injury is inferior to that of other melee units.'
    m_Metadata:
      m_Items: []
  - m_Id: 2198116110336
    m_Localized: Melee weapon with high damage output
    m_Metadata:
      m_Items: []
  - m_Id: 2200049684480
    m_Localized: 'Attacks by throwing knives.

      Requires replenishment every
      three knives, but allows for mid-range attacks.'
    m_Metadata:
      m_Items: []
  - m_Id: 52723213799424
    m_Localized: 'It''s slow, but it has a decent area-of-effect attack.

      It
      can easily destroy walls.'
    m_Metadata:
      m_Items: []
  - m_Id: 52755363139584
    m_Localized: The perfect knife for betraying your allies.
    m_Metadata:
      m_Items: []
  - m_Id: 52756340412416
    m_Localized: 'Melee sword that easily destroys projectiles

      Low damage'
    m_Metadata:
      m_Items: []
  - m_Id: 52834694205440
    m_Localized: An injection that can heal allies at close range.
    m_Metadata:
      m_Items: []
  - m_Id: 52835537260544
    m_Localized: 'Severe damage, but no injuries.

      An injection that takes
      time to prepare.'
    m_Metadata:
      m_Items: []
  - m_Id: 52940919148544
    m_Localized: Slow attack, but inflicts fatal injuries.
    m_Metadata:
      m_Items: []
  - m_Id: 52940948508672
    m_Localized: 'Poisoning knife

      Low power'
    m_Metadata:
      m_Items: []
  - m_Id: 53053473296384
    m_Localized: 'To cause the other party to become embroiled in controversy

      Be
      careful as it will brighten up the surrounding area'
    m_Metadata:
      m_Items: []
  - m_Id: 53058154139648
    m_Localized: I'll draw a line to indicate that it's a stationary type.
    m_Metadata:
      m_Items: []
  - m_Id: 53171035443200
    m_Localized: The person who was slashed suffered lacerations.
    m_Metadata:
      m_Items: []
  - m_Id: 53171941412864
    m_Localized: 'A handgun disguised as a melee weapon.

      Compared to a regular
      gun, its power and reload speed are inferior.'
    m_Metadata:
      m_Items: []
  - m_Id: 53285175037952
    m_Localized: 'Shotgun enters the melee category

      <s>Isn''t it strong in
      melee combat from the start?</s>

      Low ammo capacity and long reload
      time'
    m_Metadata:
      m_Items: []
  - m_Id: 53287066669056
    m_Localized: 'A sniper rifle suited for point-blank range shooting.

      It
      suffers from stronger power falloff at longer ranges compared to a normal rifle.'
    m_Metadata:
      m_Items: []
  - m_Id: 53384219332608
    m_Localized: A hammer with low power but strong knockback and fast swing speed.
    m_Metadata:
      m_Items: []
  - m_Id: 53388132618240
    m_Localized: It's less frequent than a normal punch, but it has more power and
      knockback.
    m_Metadata:
      m_Items: []
  - m_Id: 53486270943232
    m_Localized: You can pull in enemies that you have hit.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
