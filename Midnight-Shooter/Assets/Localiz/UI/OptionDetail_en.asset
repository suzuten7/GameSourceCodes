  - m_Id: 291122763927552
    m_Localized: Brightness outside of field of view
    m_Metadata:
      m_Items: []
  - m_Id: 291123950915584
    m_Localized: 'Switching the brightness of areas outside the field of view



      Bright

      <color=#FFCCCC>Advantages</color>:
      Obstacles outside the field of view are easier to see

      <color=#CCCCFF>Disadvantages</color>:
      It is difficult to distinguish between the visible area and the dark area



      Dark

      <color=#FFCCCC>Advantages</color>:
      It is easier to distinguish between the visible area and the dark area

      <color=#CCCCFF>Disadvantages</color>:
      Obstacles outside the field of view are harder to see'
    m_Metadata:
      m_Items: []
