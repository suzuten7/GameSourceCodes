  m_TableData:
  - m_Id: 284292872540160
    m_Localized: 'Press and hold: Activates dash mode only while dashing is being
      input.

      Toggle: Switches dash mode with each dash input.'
    m_Metadata:
      m_Items: []
  - m_Id: 283437729452032
    m_Localized: Switching between dash states
    m_Metadata:
      m_Items: []
  - m_Id: 288645024976896
    m_Localized: Switching to stealthy movement
    m_Metadata:
      m_Items: []
  - m_Id: 288647461867520
    m_Localized: 'Press and hold: Enters stealth mode only while stealth input is
      active.

      Toggle: Switches stealth mode with each stealth input.'
    m_Metadata:
      m_Items: []
  - m_Id: 289085997322240
    m_Localized: Switching aim state
    m_Metadata:
      m_Items: []
  - m_Id: 289087108812800
    m_Localized: 'Press and hold: Enters aim mode only while aiming is being input.

      Toggle:
      Switches aim mode with each aim input.'
    m_Metadata:
      m_Items: []
  - m_Id: 289268491489280
    m_Localized: Reticle movement inversion
    m_Metadata:
      m_Items: []
  - m_Id: 289269678477312
    m_Localized: 'Normal: Moves in the direction of input

      Vertical Reversal:
      Moves in the opposite direction to the [Vertical] input / Moves in the direction
      of the [Horizontal] input

      Horizontal Reversal: Moves in the direction
      of the [Vertical] input / Moves in the opposite direction to the [Horizontal]
      input

      Vertical and Horizontal Reversal: Moves in the opposite direction
      to the input'
    m_Metadata:
      m_Items: []
  - m_Id: 289438058811392
    m_Localized: Reticle Change
    m_Metadata:
      m_Items: []
