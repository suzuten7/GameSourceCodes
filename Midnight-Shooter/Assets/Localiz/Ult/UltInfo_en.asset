MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: UltInfo_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: fb48aab8a50794c4f9607a7bd2141f49, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 54851181350912
    m_Localized: For a short time, ammo becomes unlimited, and RPS increases by 50%.
    m_Metadata:
      m_Items: []
  - m_Id: 54912200085504
    m_Localized: Short-duration gadget CT scans reduced by 80%
    m_Metadata:
      m_Items: []
  - m_Id: 54914720862208
    m_Localized: It explodes, inflicting massive damage on the user and those around
      them.
    m_Metadata:
      m_Items: []
  - m_Id: 54965459357696
    m_Localized: Deploys a shield that protects against a certain amount of damage.
    m_Metadata:
      m_Items: []
  - m_Id: 55070379872256
    m_Localized: Fire a missile at the reticle position.
    m_Metadata:
      m_Items: []
  - m_Id: 55071285841920
    m_Localized: 'You become invisible to enemies for a short time.

      However,
      weapons such as guns are still visible.

      (This is a feature, not a bug.)

      You
      might be detected by sound.'
    m_Metadata:
      m_Items: []
  - m_Id: 55197869936640
    m_Localized: For a short time, enemies will become visible even if they are out
      of your line of sight.
    m_Metadata:
      m_Items: []
  - m_Id: 55311451688960
    m_Localized: Short-term movement speed increases significantly
    m_Metadata:
      m_Items: []
  - m_Id: 55312215052288
    m_Localized: 'It fires a penetrating beam of light forward.

      It takes
      time for damage to occur.'
    m_Metadata:
      m_Items: []
  - m_Id: 55381060358144
    m_Localized: 'Chases the nearest player.

      Generates a bomb at the reticle''s
      position.'
    m_Metadata:
      m_Items: []
  - m_Id: 55381693698048
    m_Localized: 'A random enemy will glow constantly.

      If you defeat the
      target, your kill score multiplier will be doubled.'
    m_Metadata:
      m_Items: []
  - m_Id: 55487931224064
    m_Localized: Inflicts slight damage on all enemies.
    m_Metadata:
      m_Items: []
  - m_Id: 55575726395392
    m_Localized: At the reticle's position, it pulls surrounding players in, creating
      a black hole.
    m_Metadata:
      m_Items: []
  - m_Id: 55577190207488
    m_Localized: Inflicts on all enemies the effect of being pulled towards the nearest
      enemy.
    m_Metadata:
      m_Items: []
  - m_Id: 55634434068480
    m_Localized: Warp to a random player's location.
    m_Metadata:
      m_Items: []
  - m_Id: 55635344232448
    m_Localized: Warp to the reticle position
    m_Metadata:
      m_Items: []
  - m_Id: 55772070154240
    m_Localized: 'Clad in the sun,

      they set surrounding enemies ablaze.'
    m_Metadata:
      m_Items: []
  - m_Id: 55772766408704
    m_Localized: 'Fly the moon

      Fly around yourself'
    m_Metadata:
      m_Items: []
  - m_Id: 55860481888256
    m_Localized: 'Inflicts the Shock status on a random enemy,

      rendering
      them unable to attack for a short

      time and slowing their movement speed.'
    m_Metadata:
      m_Items: []
  - m_Id: 55861249445888
    m_Localized: 'Stop time for everyone except yourself.

      This ability can
      be used even while another player has stopped time for you, allowing you to
      move around.'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
