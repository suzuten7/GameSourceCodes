  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=150%>\uFF08\u30B2\u30FC\u30E0\u306E\u8AAC\u660E\uFF09</size>\n2D\u30B7\u30E5\u30FC\u30C6\u30A3\u30F3\u30B0PvP\n\u81EA\u5206\u306E\u30D3\u30EB\u30C9\u3092\u7D44\u307F\u3001\u30B9\u30B3\u30A2\u3092\u7AF6\u3048!!!\n<size=150%>\uFF08HP\u3068\u8CA0\u50B7\uFF09</size>\nHP\u306F\u7DD1\u30D0\u30FC\u3067\u8868\u3055\u308C\u308B\n\u8FFD\u52A0HP\u306F\u6A59\u306E\u30D0\u30FC\u3067\u8868\u3055\u308C\u308B\n\u8CA0\u50B7\u306F\u9ED2\u3044\u30D0\u30FC\u8868\u3055\u308C\u308B\nHP\u306F\u79D2\u959310\u81EA\u52D5\u56DE\u5FA9\u3057\n\u88AB\u30C0\u30E1\u30FC\u30B8\u30673\u79D2\u9593\u4E00\u6642\u505C\u6B62\u3057\u3001\u56DE\u5FA9\u3092\u53D7\u3051\u308B\u3068\u518D\u958B\u3059\u308B\n\u8FFD\u52A0HP\u306F\u4E0A\u9650\u3092\u8D85\u3048\u305F\u56DE\u5FA9\u3067\u7372\u5F97\n\u8CA0\u50B7\u306F\u56DE\u5FA9\u51FA\u6765\u306A\u3044\u5206\n<size=150%>\uFF08\u79FB\u52D5\uFF09</size>\n\u6B69\u304D:\u9045\u3044\u304C\u97F3\u304C\u5C0F\u3055\u3044\u306E\u3067\u30D0\u30EC\u306B\u304F\u3044\n\u901A\u5E38:\u4E2D\u9593\u306E\u901F\u5EA6\u3068\u97F3\n\u8D70\u308A:\u901F\u3044\u304C\u97F3\u304C\u5927\u304D\u3044\u306E\u3067\u30D0\u30EC\u3084\u3059\u3044\n\u5834\u6240\u306B\u3088\u3063\u3066\u901F\u5EA6\u3068\u97F3\u304C\u5909\u308F\u308B\n<size=150%>\uFF08\u8996\u754C\uFF09</size>\n\u901A\u5E38\u5473\u65B9\u306E\u5468\u308A2m\u3068\u81EA\u5206\u306E\u524D\u65B990\u5EA6\u304C\u898B\u3048\n\u58C1\u306E\u5965\u306F\u898B\u3048\u306A\u3044\n\u4E00\u90E8\u5149\u308B\u7269\u3067\u3082\u898B\u3048\u308B\n\u8996\u754C\u5185\u306E\u6575\u306F\u540D\u524D\u3068HP\u304C\u8868\u793A\u3055\u308C\n\u30DF\u30CB\u30DE\u30C3\u30D7\u306B\u3082\u6620\u308B\u304C\u8302\u3084\u7159\u306A\u3069\u3067\n\u96A0\u308C\u3066\u3044\u308B\u76F8\u624B\u306F\u59FF\u4EE5\u5916\u898B\u3048\u306A\u3044\n<size=150%>\uFF08\u97F3\uFF09</size>\n\u79FB\u52D5\u3084\u653B\u6483\u3067\u767A\u751F\u3057\n\u5468\u308A\u306E\u6575\u306B\u65B9\u5411\u304C\u30D0\u30EC\u308B\n\u8996\u754C\u5916\u306F\u3053\u308C\u3067\u7D22\u6575\u3059\u308B\u3068\u3044\u3044\n<size=150%>\uFF08\u653B\u6483\uFF09</size>\n\u9283:\u57FA\u672C\u7684\u306B\u5F3E\u6570\u304C\u3042\u308A\u30EA\u30ED\u30FC\u30C9\u304C\u5FC5\u8981\n\u8FD1\u63A5:\u57FA\u672C\u7684\u306B\u5F3E\u6570\u304C\u7121\u3044\u304C\u5C04\u7A0B\u304C\u77ED\u3044<s>(\u4E2D\u8EAB\u306F\u9283\u3068\u540C\u3058)</s>\n\u30AC\u30B7\u30A7\u30C3\u30C8:CT\u3067\u30B9\u30C8\u30C3\u30AF\u304C\u5897\u3048\u3001\u4E00\u90E8\u306F\u30EC\u30C6\u30A3\u30AF\u30EB\u4F4D\u7F6E\u3067\u8ABF\u6574\u51FA\u6765\u308B\n\u5FC5\u6BBA\n\u6642\u9593\u7D4C\u904E\u3001\u4E0E\u30C0\u30E1\u30FC\u30B8\u3001\u88AB\u30C0\u30E1\u30FC\u30B8\u3001\u56DE\u907F\u5224\u5B9A\u3001\u30AD\u30EB\u3067\n\u30C1\u30E3\u30FC\u30B8\u3092\u8CAF\u3081\u308B\u5FC5\u8981\u304C\u3042\u308B\n\u9EC4\u8272\u306E\u30D0\u30FC\u3067\u8868\u3055\u308C\u3001\u6E80\u30BF\u30F3\u3067\u8679\u8272\u306B\u306A\u308B\n<size=150%>(\u64CD\u4F5C\u65B9\u6CD5)</size>\n\u8A2D\u5B9A\u753B\u9762\u898B\u3066\n\u5272\u308A\u5F53\u3066\u5909\u3048\u3089\u308C\u308B\u3088\u3084\u3063\u305F\u306D\uFF01\uFF01\uFF01\n<s>\u8AAC\u660E\u3063\u3066\u4F55\u3067\u3059\u304B</s>"
