  info: "\u30FB\u901A\u5E38\u5473\u65B9\u306E\u5468\u308A2m\u3068\u81EA\u5206\u306E\u524D\u65B990\u5EA6\u304C\u898B\u3048\u308B\n\u30FB\u58C1\u306E\u53CD\u5BFE\u306F\u898B\u3048\u306A\u3044\n\u30FB\u4E00\u90E8\u5149\u308B\u7269\u3067\u3082\u898B\u3048\u308B\n\u30FB\u8996\u754C\u5185\u306E\u6575\u306F\u540D\u524D\u3068HP\u304C\u8868\u793A\u3055\u308C\u308B\n\u30FB\u30DF\u30CB\u30DE\u30C3\u30D7\u306B\u3082\u6620\u308B\u304C\u3001\n\u3000\u8302\u3084\u7159\u306A\u3069\u3067\u96A0\u308C\u3066\u3044\u308B\u76F8\u624B\u306F\u59FF\u4EE5\u5916\u898B\u3048\u306A\u3044"
